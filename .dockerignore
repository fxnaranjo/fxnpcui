# Node modules (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (secrets should be injected via Kubernetes)
.env
.env.*
!.env.example

# Git files
.git/
.gitignore
.gitattributes

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Documentation (not needed in container)
*.md
!README.md
VERCEL_DEPLOYMENT.md
KUBERNETES_DEPLOYMENT.md

# Vercel specific files (not needed for container deployment)
vercel.json
.vercel/

# Keys directory (secrets injected via Kubernetes)
keys/

# Test files
test/
tests/
*.test.js
*.spec.js
coverage/

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Kubernetes manifests (not needed in container image)
k8s/
kubernetes/
manifests/
*.yaml
*.yml
!package.json

# Build artifacts
dist/
build/
*.log

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db
.DS_Store

# Docker files
Dockerfile*
docker-compose*.yml
.dockerignore